---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'apps'>;
}

const { entry } = Astro.props;
const d = entry.data;

const mediaCls = ['gcard-media', d.portrait ? 'gcard-media--portrait' : '']
  .filter(Boolean)
  .join(' ');

function formatShipped(shipped: string): string {
  const parts = shipped.split('-').map(Number);
  const monthNames = [
    'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December',
  ];
  const month = monthNames[parts[1] - 1];
  return parts[2] ? `${month} ${parts[2]}, ${parts[0]}` : `${month} ${parts[0]}`;
}
---
<article class="gcard" data-slug={d.slug}>
  <div class={mediaCls}>
    <Picture
      src={d.hero_image}
      formats={['avif', 'webp']}
      widths={[480, 720, 1080]}
      sizes="(max-width: 880px) 100vw, 540px"
      alt={`${d.name} preview`}
      class="gcard-img"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="gcard-body">
    <h3 class="gcard-name">{d.name}</h3>
    <p class="gcard-tagline">{d.tagline}</p>
    <ul class="gcard-chips">
      {d.stack.map((s) => <li class="chip-mono">{s}</li>)}
    </ul>
    <p class="gcard-blurb">{d.blurb}</p>
    <footer class="gcard-foot">
      <div class="gcard-byline">
        <span class="gcard-byline-item">
          <span class="gcard-byline-label">Author</span>
          <span class="gcard-byline-value">{d.built_by}</span>
        </span>
        <span class="gcard-byline-dot" aria-hidden="true">·</span>
        <span class="gcard-byline-item">
          <span class="gcard-byline-label">Published</span>
          <span class="gcard-byline-value">{formatShipped(d.shipped)}</span>
        </span>
      </div>
      <span class="gcard-links">
        {d.guest_credentials && (
          <button
            type="button"
            class="btn btn-copy-login"
            data-copy-login
            data-email={d.guest_credentials.email}
            data-password={d.guest_credentials.password}
            aria-label={`Copy guest login (${d.guest_credentials.email})`}
            title={`Copy guest login (${d.guest_credentials.email})`}
          >Copy login</button>
        )}
        {d.live_url && <a class="btn btn-primary" href={d.live_url}>Live</a>}
        <a class="btn" href={d.repo_url}>Repo</a>
      </span>
    </footer>
  </div>
</article>
