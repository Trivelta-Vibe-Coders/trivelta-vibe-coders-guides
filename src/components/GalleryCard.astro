---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'apps'>;
}

const { entry } = Astro.props;
const d = entry.data;

// Mascots / illustrations opt into a centered, padded layout via `portrait: true`
// in their frontmatter. Real screenshots use the default 4:3 cover crop.
const mediaCls = ['gcard-media', d.portrait ? 'gcard-media--portrait' : '']
  .filter(Boolean)
  .join(' ');
---
<article class="gcard" data-slug={d.slug}>
  <div class={mediaCls}>
    <Picture
      src={d.hero_image}
      formats={['avif', 'webp']}
      widths={[480, 720, 1080]}
      sizes="(max-width: 880px) 100vw, 540px"
      alt={`${d.name} preview`}
      class="gcard-img"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="gcard-body">
    <h3 class="gcard-name">{d.name}</h3>
    <p class="gcard-tagline">{d.tagline}</p>
    <ul class="gcard-chips">
      {d.stack.map((s) => <li class="chip-mono">{s}</li>)}
    </ul>
    <p class="gcard-blurb">{d.blurb}</p>
    <footer class="gcard-foot">
      <span class="gcard-meta">
        {d.built_by} · {d.shipped}
        {d.live && <> · <span class="badge badge-live">live</span></>}
        {d.internal && <> · <span class="badge badge-internal">internal</span></>}
      </span>
      <span class="gcard-links">
        {d.guest_credentials && (
          <button
            type="button"
            class="btn btn-copy-login"
            data-copy-login
            data-email={d.guest_credentials.email}
            data-password={d.guest_credentials.password}
            aria-label={`Copy guest login (${d.guest_credentials.email})`}
            title={`Copy guest login (${d.guest_credentials.email})`}
          >Copy login</button>
        )}
        {d.live_url && <a class="btn btn-primary" href={d.live_url}>Live</a>}
        <a class="btn" href={d.repo_url}>Repo</a>
      </span>
    </footer>
  </div>
</article>
