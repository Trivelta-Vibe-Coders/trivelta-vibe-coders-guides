---
interface Props {
  chip: string;
  title: string;
  first?: boolean;
  topRule?: boolean;
}
const { chip, title, first = false, topRule = false } = Astro.props;
const cls = ['step', first ? 'step--first' : '', topRule ? 'step--top-rule' : '']
  .filter(Boolean)
  .join(' ');
const isNumeric = /^\d+$/.test(chip);
const tag = isNumeric ? `[${chip.padStart(2, '0')}]` : `[${chip}]`;
---
<div class={cls}>
  <span class="step-tag">{tag}</span>
  <div>
    <h4>{title}</h4>
    <slot />
  </div>
</div>
